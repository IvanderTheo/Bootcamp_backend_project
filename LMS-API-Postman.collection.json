    {
      "name": "Advanced Queries",
      "item": [
        {
          "name": "Get Instructor Course Count (Aggregation)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains instructor statistics', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql('success');",
                  "    pm.expect(Array.isArray(jsonData.data)).to.be.true;",
                  "});",
                  "",
                  "pm.test('Each instructor has course count', function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data.length > 0) {",
                  "        pm.expect(jsonData.data[0]).to.have.property('course_count');",
                  "        pm.expect(jsonData.data[0]).to.have.property('total_students_enrolled');",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/instructors/course-count",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "instructors",
                "course-count"
              ]
            }
          }
        },
        {
          "name": "Get Transactions Detail (JOIN Multi-table)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains transaction details', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql('success');",
                  "    pm.expect(jsonData.data).to.exist;",
                  "});",
                  "",
                  "pm.test('Transaction data has joined information', function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data.data && jsonData.data.data.length > 0) {",
                  "        var transaction = jsonData.data.data[0];",
                  "        pm.expect(transaction).to.have.property('student_name');",
                  "        pm.expect(transaction).to.have.property('course_name');",
                  "        pm.expect(transaction).to.have.property('category_name');",
                  "        pm.expect(transaction).to.have.property('instructor_name');",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
